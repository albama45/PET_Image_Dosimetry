#functions to store and charge data:

def Pickle_save(nombre,Geometry,actividad):
  #nombre es el nombre que tendrá el archivo final
  #geometry es la clase geometry definada para legpy tras la simulación.
  #actividad es la actividad para la que se ha simulado

  matrix=Geometry.voxelization.matrix
  datos=[matrix,actividad] # Se guarda la matriz e energía depositada y la actividad a la que se ha simulado
  with open(nombre+'.pkl', 'wb') as f:
    pickle.dump(datos, f)



def Pickle_load(ruta,actividad):
  #ruta es la ruta hasta el archivo de la matriz
  #actividad es la actividad deseada, se usa para reescalar la matriz guardada

  with open(ruta, 'rb') as f:
    datos_recuperados = pickle.load(f)

  matriz=datos_recuperados[0]
  actividad_original=datos_recuperados[1]

  matriz_reescalada=matriz*actividad/actividad_original # se reescala la matriz para obtener la actividad deseada
  return matriz_reescalada

