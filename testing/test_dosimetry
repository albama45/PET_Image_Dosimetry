
#Checking the convolution process: function that plots 1D profiles
#Comprobación de convolución: perfiles eje x y eje z de la actividad y la dosis.

#vector 1D plano xz horizontar y vertical, a la altura de la vejiga, para ver la intensidad antes y después de convolucionar
#en esta nueva imagen me interesa para la vejiga: plano z-x a z 250 y x -60

def plot_profiles(A, D, y0, x0=None, z0=None):
    # Asume A.shape == (nx, ny, nz)
    nx, ny, nz = A.shape
    assert A.shape == D.shape, "A y D deben tener la misma shape"
    assert 0 <= y0 < ny

    if x0 is None:
        x0 = nx // 2
    if z0 is None:
        z0 = nz // 2

    # 1) Perfil horizontal en el plano xz (y fijo, z fijo): varía x
    A_x = A[:, y0, z0]
    D_x = D[:, y0, z0]



    # 2) Perfil vertical en el mismo plano (y fijo, x fijo): varía z
    A_z = A[x0, y0, :]
    D_z = D[x0, y0, :]



    return A_x, D_x, A_z, D_z

