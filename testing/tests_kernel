# 1D profiles:

import numpy as np
import matplotlib.pyplot as plt

#Comprobación de perfiles unidimensionales de energía depositada

# =========================
# Parámetros del vóxel
# =========================
dx = 5.3067   # mm
dy = 5.3067    # mm
dz = 3.3750001   # mm

# =========================
# Dimensiones del kernel
# =========================
nx, ny, nz = K.shape

# Índice de la fuente (asumo centro)
ix = nx // 2
iy = ny // 2
iz = nz // 2

print(ix, iy, iz)
# =========================
# 1) Perfil sobre la recta x=ix, y=iy
# =========================
E_rad_z = np.array(K[ix, iy, :])
z_mm = np.arange(nz) * dz

plt.figure(figsize=(7, 4.5))
plt.plot(z_mm, E_rad_z, '-o')
plt.xlabel('Coordenada z (mm)')
plt.ylabel('Energía depositada (MeV/desintegración)')
plt.title(f'Perfil de energía depositada sobre la recta x={ix}, y={iy}')
plt.grid(True, alpha=0.3)
plt.tight_layout()
plt.show()

# =========================
# 2) Perfil sobre la diagonal x=y=z
# =========================
n_diag = min(nx, ny, nz)
E_diag = np.array([K[i, i, i] for i in range(n_diag)])

# Si dx=dy=dz, esto es distancia física sobre la diagonal
if np.isclose(dx, dy) and np.isclose(dy, dz):
    s_mm = np.sqrt(3) * np.arange(n_diag) * dx
    xlabel_diag = 'Distancia sobre la diagonal (mm)'
else:
    # Si los vóxeles no son cúbicos, uso distancia euclídea real
    s_mm = np.array([
        np.sqrt((i * dx)**2 + (i * dy)**2 + (i * dz)**2)
        for i in range(n_diag)
    ])
    xlabel_diag = 'Distancia sobre la diagonal (mm)'

plt.figure(figsize=(7, 4.5))
plt.plot(s_mm, E_diag, '-o')
plt.xlabel(xlabel_diag)
plt.ylabel('Energía depositada (MeV/desintegración)')
plt.title('Perfil de energía depositada sobre la diagonal x=y=z')
plt.grid(True, alpha=0.3)
plt.tight_layout()
plt.show()

# =========================
# 3) Representación geométrica 3D en mm
# =========================
fig = plt.figure(figsize=(8, 7))
ax = fig.add_subplot(111, projection='3d')

# Límites físicos
xmax = (nx - 1) * dx
ymax = (ny - 1) * dy
zmax = (nz - 1) * dz

p_x = [0, xmax]
p_y = [0, ymax]
p_z = [0, zmax]

# Dibujar aristas de la caja
for x in p_x:
    for y in p_y:
        ax.plot([x, x], [y, y], p_z, color="steelblue", alpha=0.5)

for x in p_x:
    for z in p_z:
        ax.plot([x, x], p_y, [z, z], color="steelblue", alpha=0.5)

for y in p_y:
    for z in p_z:
        ax.plot(p_x, [y, y], [z, z], color="steelblue", alpha=0.5)

# Plano x = ix
y_plane = np.linspace(0, ymax, 30)
z_plane = np.linspace(0, zmax, 30)
Yp, Zp = np.meshgrid(y_plane, z_plane)
Xp = np.full_like(Yp, ix * dx)
ax.plot_surface(Xp, Yp, Zp, color='royalblue', alpha=0.18, linewidth=0)

# Plano y = iy
x_plane = np.linspace(0, xmax, 30)
z_plane = np.linspace(0, zmax, 30)
Xp2, Zp2 = np.meshgrid(x_plane, z_plane)
Yp2 = np.full_like(Xp2, iy * dy)
ax.plot_surface(Xp2, Yp2, Zp2, color='green', alpha=0.18, linewidth=0)

# Recta x=ix, y=iy
ax.plot(
    [ix * dx, ix * dx],
    [iy * dy, iy * dy],
    [0, zmax],
    color='red',
    linewidth=3,
    label=f'Recta x={int(ix*dx)}, y={int(iy*dy)}'
)

# Diagonal
n_line = min(nx, ny, nz)
ax.plot(
    np.arange(n_line) * dx,
    np.arange(n_line) * dy,
    np.arange(n_line) * dz,
    color='purple',
    linewidth=3,
    label='Diagonal x=y=z'
)

# Fuente
ax.scatter([ix * dx], [iy * dy], [iz * dz], color='black', s=50)
ax.text(ix * dx, iy * dy, iz * dz + 0.8 * dz, "Fuente",
        color='black', fontsize=10, ha='center')

# Etiquetas
ax.text(ix * dx, iy * dy + 0.5 * dy, zmax, f"Recta x={int(ix*dx)}, y={int(iy*dy)}",
        color='red', fontsize=9, ha='center')
ax.text(ix * dx, ymax, 0, f"Plano x={int(ix*dx)}",
        color='royalblue', fontsize=9, ha='center')
ax.text(0, iy * dy, 0, f"Plano y={int(iy*dy)}",
        color='green', fontsize=9, ha='center')
ax.text(0.7 * xmax, 0.7 * ymax, 0.15 * zmax, "Diagonal x=y=z",
        color='purple', fontsize=9, ha='center')

ax.set_xlim([0, xmax])
ax.set_ylim([0, ymax])
ax.set_zlim([0, zmax])

ax.set_box_aspect([xmax, ymax, zmax])
ax.set_xlabel('X (mm)')
ax.set_ylabel('Y (mm)')
ax.set_zlabel('Z (mm)')
ax.set_title('Representación geométrica de los perfiles analizados', fontsize=14)

ax.legend(loc='upper left')
plt.tight_layout()
plt.show()

