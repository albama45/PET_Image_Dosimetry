#cmap in logarithmic scale:

import numpy as np
import matplotlib.pyplot as plt
from matplotlib.colors import LogNorm


#mapas de color del kernel en escala logarítmica

K_plot = np.ma.masked_less_equal(K, 0)
norm = LogNorm(vmin=K_plot.min(), vmax=K_plot.max())

cmap = plt.cm.viridis.copy()
cmap.set_bad(color='black', alpha=1.0)

ix = img_shape[0] // 2
iy = img_shape[1] // 2
iz = img_shape[2] // 2


fig, axs = plt.subplots(1, 3, figsize=(12, 4), constrained_layout=True)
fig.suptitle("Kernel de dosis (escala logarítmica)", fontsize=14)
# Plano xy
im1 = axs[0].imshow(K_plot[:, :, iz], cmap=cmap, norm=norm, origin='lower')
axs[0].set_title("Plano xy")
axs[0].set_xlabel("x (vóxel)")
axs[0].set_ylabel("y (vóxel)")

# Plano xz
im2 = axs[1].imshow(K_plot[:, iy, :], cmap=cmap, norm=norm, origin='lower')
axs[1].set_title("Plano xz")
axs[1].set_xlabel("x (vóxel)")
axs[1].set_ylabel("z (vóxel)")

# Plano yz
im3 = axs[2].imshow(K_plot[ix, :, :], cmap=cmap, norm=norm, origin='lower')
axs[2].set_title("Plano yz")
axs[2].set_xlabel("y (vóxel)")
axs[2].set_ylabel("z (vóxel)")


cbar = fig.colorbar(im3, ax=axs, fraction=0.02, pad=0.04)
cbar.set_label("Energía depositada (MeV/desintegración)")

plt.savefig("kernel_planos.png", dpi=300, bbox_inches="tight")
plt.show()

