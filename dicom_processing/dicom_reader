#Visualising the image


#Defino una función para mostrar imágenes
def visualizar(body, v_size, unitsx, unitsy): #body es la "imagen volumétrica que quiero mostrar", v_size es el tamaño del vóxel de imagen, unitx y unity permiten adaptar las unidades de los ejes.
  dx = v_size[0]
  dy = v_size[1]
  dz = v_size[2]

  pixel_spacing = [dx, dy]
  slice_thickness = dz

  nx, ny, nz = body.shape

  if unitsx == 'voxel':
    plt.figure()
    z_mid = nz // 2
    plt.imshow(np.rot90(body[:, :, z_mid],0),
              cmap='viridis',
              origin='lower')
    plt.xlabel(f"x ({unitsx})")
    plt.ylabel(f"y ({unitsx})")
    plt.title("Plano XY (axial)")
    plt.colorbar(label=f"{unitsy}")
    plt.show()

    plt.figure()
    y_mid = ny // 2
    plt.imshow(np.rot90(body[:, y_mid, :], 1),
              cmap='viridis',
              origin='lower',
              aspect='auto')
    plt.xlabel(f"y ({unitsx})")
    plt.ylabel(f"z ({unitsx})")
    plt.title("Plano YZ (sagital)")
    plt.colorbar(label=f"{unitsy}")
    plt.show()

    plt.figure()
    x_mid = nx // 2
    plt.imshow(np.rot90(body[x_mid, :, :], 1),
           cmap='viridis',
           origin='lower',
           aspect='auto')
    plt.xlabel(f"x ({unitsx})")
    plt.ylabel(f"z ({unitsx})")
    plt.title("Plano XZ (coronal)")
    plt.colorbar(label=f"{unitsy}")
    plt.show()

  elif unitsx == 'cm':
    plt.figure()
    z_mid = nz // 2
    extent_xy = [
        0, nx * 0.1*pixel_spacing[0],
        0, ny * 0.1*pixel_spacing[1]
    ]
    plt.imshow(np.rot90(body[:, :, z_mid], 0),
            cmap='viridis',
            extent=extent_xy,
            origin='lower')
    plt.xlabel(f"x ({unitsx})")
    plt.ylabel(f"y ({unitsx})")
    plt.title("Plano XY (axial)")
    plt.colorbar(label=f"{unitsy}")
    plt.show()

    plt.figure()
    y_mid = ny // 2
    extent_xz = [
        0, nx * 0.1*pixel_spacing[0],
        0, nz * 0.1*slice_thickness
    ]
    print(extent_xz)
    plt.imshow(np.rot90(body[:, y_mid, :], 1),
            cmap='viridis',
            extent=extent_xz,
            origin='lower',
            aspect='auto')
    plt.xlabel(f"y ({unitsx})")
    plt.ylabel(f"z ({unitsx})")
    plt.title("Plano YZ (sagital)")
    plt.colorbar(label=f"{unitsy}")
    plt.show()

    plt.figure()
    x_mid = nx // 2
    extent_yz = [
        0, ny * 0.1*pixel_spacing[1],
        0, nz * 0.1*slice_thickness
    ]
    plt.imshow(np.rot90(body[x_mid, :, :], 1),
            cmap='viridis',
            extent=extent_yz,
            origin='lower',
            aspect='auto')
    plt.xlabel(f"x ({unitsx})")
    plt.ylabel(f"z ({unitsx})")
    plt.title("Plano XZ (coronal)")
    plt.colorbar(label=f"{unitsy}")
    plt.show()

  else:
    print('error')


# muestro los cortes PET antes de pasar a actividad

visualizar(body, v_size, 'cm','intensidad')
