#Extracting the image

#defino una función genérica para obtener una estructura 3D que contenga los datos píxel de la tomografía completa (una "imagen volumétrica del cuerpo del paciente")

def obtencion_body(ruta):


  archivos_nombre = [f for f in os.listdir(ruta) if os.path.isfile(os.path.join(ruta, f))]
  archivos_nombre.sort()
  #print(archivos_nombre) #archivos_nombre es una lista del nombre de los ficheros en la carpeta Datos! ordenados numéricamente!!

  archivos = []
  archivos = [pydicom.dcmread(os.path.join(ruta, nombre)) for nombre in archivos_nombre] #archivos contiene los ficheros DICOM!! con toda su info

  thickness = []
  locations = []

  for i in range(len(archivos)):

    locations.append(archivos[i].SliceLocation)
    thickness.append(archivos[i].SliceThickness)

  locations_ordenado = sorted(locations, reverse=True)          
  indices_orden = sorted(range(len(locations)), key=lambda i: locations[i], reverse=True)

  thickness_ordenada = [thickness[i] for i in indices_orden]

  archivos_orden = [archivos[i] for i in indices_orden]  #coloco según coordenadas en el eje z
  archivos_orden = archivos_orden[::-1]

  dx = archivos[0].PixelSpacing[0]
  dy = archivos[0].PixelSpacing[1]  
  dz = archivos[0].SliceThickness

  v_size = [dx, dy, dz]

  # print(locations)
  # print(thickness)
  # print(archivos)
  #creo un body vacío:

  img_shape = list(archivos[0].pixel_array.shape) # matriz i j
  img_shape.append(len(archivos)) #añado una tercera coordenada, k, que es tan larga como imagenes hay en archivos (z en realidad será k*thickness(k))

  #print(img_shape)
  body = np.zeros(img_shape)

  #relleno
  for i, s in enumerate(archivos):     #i es el índice, osea lo que equivale a j en img3d; s es el elemento, osea mi ds de antes
      img2d = s.pixel_array
      body[:, :, i] = img2d            # todas las filas y columnas, para la posición k= i. Es decir, asigno la slice a su posición en el objeto 3D
  return body, v_size, thickness_ordenada, locations_ordenado, archivos



#Utilizo la función para obtener body de los datos PET

ruta1 = "/content/DatosPET/"
[body, v_size, thickness_ordenada, locations_ordenado, archivos] = obtencion_body(ruta1)


