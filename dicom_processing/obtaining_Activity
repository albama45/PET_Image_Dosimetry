#Slider that allows to visualize the activity image:

#Esta celda muestra la actividad en un visor, de forma que se puede explorar de forma manual el cuerpo del paciente

from ipywidgets import interact, IntSlider

def visor_coronal(vol):
    xmax = vol.shape[0] - 1

    def mostrar(x):
        plt.figure(figsize=(6,6))
        plt.imshow(vol[x, :, :], cmap='viridis')
        plt.title(f"Plano coronal - x = {x}")
        plt.xlabel("z (voxel)")
        plt.ylabel("y (voxel)")
        plt.colorbar(label="Intensidad")
        plt.show()

    interact(mostrar, x=IntSlider(min=0, max=xmax, step=1, value=xmax//2))

def visor_sagital(vol):
    ymax = vol.shape[1] - 1

    def mostrar(y):
        plt.figure(figsize=(6,6))
        plt.imshow(vol[:, y, :], cmap='viridis', aspect='auto')
        plt.title(f"Plano sagital - y = {y}")
        plt.xlabel("z (voxel)")
        plt.ylabel("x (voxel)")
        plt.colorbar(label="Intensidad")
        plt.show()

    interact(mostrar, y=IntSlider(min=0, max=ymax, step=1, value=ymax//2))

def visor_axial(vol):
    zmax = vol.shape[2] - 1

    def mostrar(z):
        plt.figure(figsize=(6,6))
        plt.imshow(vol[:, :, z], cmap='viridis', aspect='auto')
        plt.title(f"Plano axial - z  = {z}")
        plt.xlabel("x (voxel)")
        plt.ylabel("y (voxel)")
        plt.colorbar(label="Intensidad")
        plt.show()

    interact(mostrar, z=IntSlider(min=0, max=zmax, step=1, value=zmax//2))

