#Conversion from Activity (Bq/ml) to SUV:

#Defino una función para pasar el tiempo de formato DICOM , por ejemplo 1325 (13h 25min) a s

def dicom_time_to_seconds(t):
    t = str(t).split('.')[0]   # viene como '134745.484000'
    t = t.zfill(6)             # asegura 6 dígitos
    h = int(t[0:2])
    m = int(t[2:4])
    s = int(t[4:6]) #separo los strings de dos en dos
    return h*3600 + m*60 + s


