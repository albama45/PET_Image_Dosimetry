#función para cargar el kernel (dosis depositada por los fotones de aniquilación electrón-positrón)

def Pickle_load(ruta,actividad):
  #ruta es la ruta hasta el archivo de la matriz
  #actividad es la actividad deseada, se usa para reescalar la matriz guardada

  with open(ruta, 'rb') as f:
    datos_recuperados = pickle.load(f)

  matriz=datos_recuperados[0]
  actividad_original=datos_recuperados[1]

  matriz_reescalada=matriz*actividad/actividad_original # se reescala la matriz para obtener la actividad deseada
  return matriz_reescalada
